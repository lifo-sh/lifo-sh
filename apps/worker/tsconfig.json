{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "paths": {
      "@lifo-sh/core": ["../../packages/core/src"],
      "@lifo-sh/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src"]
}
